# Build output
node_modules
dist
.vite
tsconfig.tsbuildinfo

# OS / editor
.DS_Store

# Local environment
.env
.env.local
*.local

# Claude Code: ignore per-user local working dir, but keep shared project
# config (settings.json + hooks) tracked so SessionStart runs for every session.
.claude/*
!.claude/settings.json
!.claude/hooks/
.claude/settings.local.json

# Real session data synced from local agent transcripts.
# Contains private prompts, paths, commands, diffs, and tool outputs.
# NEVER commit. The tracked stub at src/data/claudeSessions.json stays as `[]`.
src/data/claudeSessions.local.json
src/data/codexSessions.local.json

# Editor cruft
*.swp
*.swo
*.code-workspace
